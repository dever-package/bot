{
  "page": {
    "parent": "bot/energon/service_endpoint/list",
    "type": 2,
    "sort": 11
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "value": "form.api",
        "mode": "form",
        "placeholder": "例如：gpt-image-2-all、gpt-4o、workflow ID 或 /openapi/v2/xxx",
