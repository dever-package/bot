        "meta": {
          "controlClassName": "min-w-[12rem]"
        }
      },
      {
        "type": "form-array",
        "name": "关联参数",
        "value": "form.param_ids",
        "mode": "form",
        "info": "参数直接来自内部参数表。每行先选参数分类，再选参数。",
        "meta": {
          "pageRoute": "/bot/energon/service_endpoint/param",
          "addText": "添加关联参数",
          "drag": "sort",
          "itemName": "关联参数",
          "valueFormat": "json"
        }
      }
    ]
  },
  "data": {
    "form": {
      "param_mode": "all",
      "param_ids": [],
      "status": 1,
      "sort": 100
    },
    "option": {
      "param_mode": [
        {
          "id": "all",
          "value": "全部参数满足"
