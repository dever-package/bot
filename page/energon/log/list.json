{
  "page": {
    "icon": "list-checks",
    "parent": "bot-energon",
    "sort": 4
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header"
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5 sm:gap-6",
        "children": {
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          },
          "feedback-shell": {
            "type": "container"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page",
        "className": "min-w-0 flex-1"
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "rowKey": "id",
          "columns": [
            {
              "value": "request_id",
              "type": "show-base"
            },
            {
              "value": "mode",
              "type": "show-tag"
            },
            {
              "value": "protocol",
              "type": "show-tag"
            },
            {
              "value": "power_name",
              "type": "show-base"
            },
            {
              "value": "status",
              "type": "show-tag"
            },
            {
              "value": "latency",
              "type": "show-base"
            },
            {
              "value": "created_at",
              "type": "show-date"
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "eye",
                    "variant": "outline",
                    "size": "sm",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.viewLogId",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.view",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "feedback-shell": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.view",
          "pageRoute": "/bot/energon/log/view",
          "description": "查看本次请求的能力、来源、参数与响应数据。",
          "size": "xl",
          "bodyClassName": "max-h-[65vh] overflow-y-auto px-6 py-2",
          "pageRouteQuery": {
            "id": "data.actionTarget.viewLogId"
          }
        }
      }
    ]
  },
  "data": {
    "page": {
      "description": "记录每次能力调用实际命中的来源、账号、能力来源、参数与耗时。"
    },
    "table": {
      "page": 1,
      "pageSize": 10,
      "total": 0
    },
    "actionTarget": {
      "viewLogId": ""
    }
  },
  "state": {
    "dialog": {
      "view": false
    }
  },
  "action": {}
}
