{
  "page": {
    "parent": "bot/energon/param/list",
    "sort": 10
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-select",
        "value": "form.cate_id",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "参数分类不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[260px]"
        }
      },
      {
        "type": "form-input",
        "value": "form.name",
        "mode": "form",
        "placeholder": "例如：提示词",
        "validate": [
          {
            "type": "required",
            "message": "参数名不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "value": "form.key",
        "mode": "form",
        "placeholder": "例如：prompt",
        "validate": [
          {
            "type": "required",
            "message": "参数标识不能为空。"
          },
          {
            "type": "model",
            "except": "$form.id",
            "message": "该参数标识在当前分类下已存在。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-radio",
        "value": "form.usage",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "参数用途不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[220px]"
        }
      },
      {
        "type": "form-radio",
        "value": "form.type",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "参数类型不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[220px]"
        }
      },
      {
        "type": "form-radio",
        "value": "form.value_type",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "值类型不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[220px]"
        }
      },
      {
        "type": "form-select",
        "value": "form.upload_rule_id",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "上传规则不能为空。",
            "when": [
              {
                "path": "form.type",
                "operator": "includes",
                "value": "file"
              }
            ]
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[260px]",
          "showWhen": [
            {
              "path": "form.type",
              "operator": "includes",
              "value": "file"
            }
          ]
        }
      },
      {
        "type": "form-number",
        "value": "form.max_files",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[160px]",
          "showWhen": [
            {
              "path": "form.type",
              "operator": "equals",
              "value": "files"
            }
          ]
        }
      },
      {
        "type": "form-array",
        "value": "form.options",
        "mode": "form",
        "info": "仅单选和多选参数需要维护选项。",
        "meta": {
          "formLayout": "horizontal",
          "pageRoute": "/bot/energon/param_option/update",
          "addText": "添加选项",
          "drag": "sort",
          "showWhen": [
            {
              "path": "form.type",
              "operator": "includes",
              "value": "option"
            }
          ]
        }
      },
      {
        "type": "form-textarea",
        "value": "form.default_value",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "隐藏框必须填写默认值。",
            "when": [
              {
                "path": "form.type",
                "operator": "equals",
                "value": "hidden"
              }
            ]
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "rows": 4
        }
      }
    ]
  },
  "data": {
    "form": {
      "cate_id": 1,
      "usage": 1,
      "type": "textarea",
      "value_type": "string",
      "upload_rule_id": 1,
      "max_files": 5,
      "default_value": "",
      "options": []
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "type": "service",
        "use": "bot.energon.hook.ParamHook.BeforeSaveParam"
      }
    }
  }
}
