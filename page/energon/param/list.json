{
  "page": {
    "icon": "sliders-horizontal",
    "parent": "bot-energon",
    "sort": 2
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "className": "gap-4",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5 sm:gap-6",
        "children": {
          "content-shell": {
            "type": "container",
            "className": "front-two-pane-layout",
            "children": {
              "category-column": {
                "type": "container",
                "className": "min-w-0",
                "path": "/bot/energon/param_cate/list",
                "meta": {
                  "updateDocumentTitle": false
                }
              },
              "list-column": {
                "type": "container",
                "className": "flex min-w-0 flex-col gap-4",
                "children": {
                  "content-toolbar": {
                    "type": "row",
                    "className": "flex-wrap items-center gap-3"
                  },
                  "table-row": {
                    "type": "container",
                    "className": "overflow-hidden rounded-md border bg-background"
                  }
                }
              }
            }
          },
          "feedback-shell": {
            "type": "container"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page",
        "className": "min-w-0 flex-1"
      }
    ],
    "header-actions": [
      {
        "type": "show-button",
        "className": "shrink-0",
        "meta": {
          "variant": "default",
          "size": "sm"
        },
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.create",
            "value": true
          }
        }
      }
    ],
    "content-toolbar": [
      {
        "type": "form-input",
        "placeholder": "筛选参数名或标识...",
        "value": "search.keyword",
        "mode": "search"
      },
      {
        "type": "form-select",
        "placeholder": "类型",
        "value": "search.type",
        "mode": "search"
      },
      {
        "type": "form-select",
        "placeholder": "用途",
        "value": "search.usage",
        "mode": "search"
      },
      {
        "type": "form-select",
        "placeholder": "值类型",
        "value": "search.value_type",
        "mode": "search"
      },
      {
        "type": "form-select",
        "placeholder": "状态",
        "value": "search.status",
        "mode": "search"
      },
      {
        "type": "show-button",
        "name": "搜索",
        "meta": {
          "variant": "default",
          "size": "sm",
          "searchSubmit": true,
          "loadingText": "搜索中..."
        }
      },
      {
        "type": "show-button",
        "name": "重置",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "to": "/bot/energon/param/list"
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "savePath": "bot/energon/param/update",
          "rowKey": "id",
          "columns": [
            {
              "value": "name",
              "type": "show-base"
            },
            {
              "value": "key",
              "type": "show-base"
            },
            {
              "value": "type",
              "type": "show-tag"
            },
            {
              "value": "usage",
              "type": "show-tag"
            },
            {
              "value": "value_type",
              "type": "show-tag"
            },
            {
              "value": "default_value",
              "type": "show-base"
            },
            {
              "value": "status",
              "type": "form-switch",
              "meta": {
                "trueValue": 1,
                "falseValue": 2
              }
            },
            {
              "value": "sort",
              "type": "show-base",
              "editor": "form-number",
              "trigger": "doubleClick",
              "tip": "正序排序，数值越大越靠后。双击可修改。",
              "meta": {
                "controlClassName": "w-24"
              }
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "square-pen",
                    "variant": "outline",
                    "size": "sm",
                    "description": "编辑参数",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.id",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.edit",
                          "value": true
                        }
                      ]
                    }
                  },
                  {
                    "icon": "trash-2",
                    "variant": "outline",
                    "size": "sm",
                    "description": "删除参数",
                    "className": "text-destructive hover:text-destructive",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.deleteParam",
                          "value": "$row"
                        },
                        {
                          "type": "modal",
                          "key": "confirm.delete",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "feedback-shell": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.create",
          "pageRoute": "/bot/energon/param/update",
          "description": "新增参数会默认带入当前左侧分类。",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "cate_id": "data.search.cate_id"
          },
          "bodyClassName": "py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.edit",
          "pageRoute": "/bot/energon/param/update",
          "description": "参数类型变化时，会自动清理不再适用的选项或上传规则。",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.id"
          },
          "bodyClassName": "py-2"
        }
      },
      {
        "type": "feedback-confirm",
        "name": "删除参数",
        "info": "确认删除当前参数吗？删除后参数选项、能力参数和服务参数映射会一并清理。",
        "meta": {
          "stateKey": "confirm.delete"
        },
        "action": {
          "confirm": {
            "type": "delete",
            "params": "actionTarget.deleteParam",
            "before": {
              "type": "service",
              "use": "bot.energon.ParamHook.BeforeDeleteParam"
            }
          }
        }
      }
    ]
  },
  "data": {
    "page": {
      "description": "左侧维护参数分类，右侧维护系统内部统一入参。"
    },
    "search": {
      "keyword": "",
      "cate_id": "",
      "type": "",
      "usage": "",
      "value_type": "",
      "status": ""
    },
    "table": {
      "page": 1,
      "pageSize": 10,
      "total": 0,
      "searchFields": [
        "name",
        "key"
      ],
      "filterFields": [
        "cate_id",
        "type",
        "usage",
        "value_type",
        "status"
      ]
    },
    "actionTarget": {
      "id": "",
      "deleteParam": {}
    }
  },
  "state": {
    "dialog": {
      "create": false,
      "edit": false
    },
    "confirm": {
      "delete": false
    }
  },
  "action": {}
}
