{
  "page": {
    "icon": "zap",
    "parent": "bot-energon",
    "sort": 3
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "className": "gap-4",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5 sm:gap-6",
        "children": {
          "content-shell": {
            "type": "container",
            "className": "front-two-pane-layout",
            "children": {
              "category-column": {
                "type": "container",
                "className": "min-w-0",
                "path": "/bot/energon/power_cate/list",
                "meta": {
                  "updateDocumentTitle": false
                }
              },
              "list-column": {
                "type": "container",
                "className": "flex min-w-0 flex-col gap-4",
                "children": {
                  "table-row": {
                    "type": "container",
                    "className": "overflow-hidden rounded-md border bg-background"
                  }
                }
              }
            }
          },
          "feedback-shell": {
            "type": "container"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page",
        "className": "min-w-0 flex-1"
      }
    ],
    "header-actions": [
      {
        "type": "show-button",
        "meta": {
          "variant": "default",
          "size": "sm"
        },
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.create",
            "value": true
          }
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "savePath": "bot/energon/power/update",
          "rowKey": "id",
          "columns": [
            {
              "value": "name",
              "type": "show-base"
            },
            {
              "value": "key",
              "type": "show-base"
            },
            {
              "value": "kind",
              "type": "show-tag"
            },
            {
              "value": "status",
              "type": "form-switch",
              "meta": {
                "trueValue": 1,
                "falseValue": 2
              }
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "square-pen",
                    "variant": "outline",
                    "size": "sm",
                    "description": "编辑能力",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.id",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.edit",
                          "value": true
                        }
                      ]
                    }
                  },
                  {
                    "icon": "message-circle",
                    "variant": "outline",
                    "size": "sm",
                    "description": "调用能力",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.runPower",
                          "value": "$row"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.run",
                          "value": true
                        }
                      ]
                    }
                  },
                  {
                    "icon": "trash-2",
                    "variant": "outline",
                    "size": "sm",
                    "description": "删除能力",
                    "className": "text-destructive hover:text-destructive",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.deletePower",
                          "value": "$row"
                        },
                        {
                          "type": "modal",
                          "key": "confirm.delete",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "feedback-shell": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.edit",
          "pageRoute": "/bot/energon/power/update",
          "size": "xl",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.id"
          }
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.create",
          "pageRoute": "/bot/energon/power/update",
          "size": "xl",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "cate_id": "data.search.cate_id"
          }
        }
      },
      {
        "type": "feedback-modal",
        "name": "调用能力",
        "info": "配置参数后，将通过当前能力的流式调用实时返回内容。",
        "meta": {
          "stateKey": "dialog.run",
          "formSection": "power-run-panel",
          "titleNamePath": "data.actionTarget.runPower.name",
          "titleKeyPath": "data.actionTarget.runPower.key",
          "size": "2xl",
          "bodyScroll": false,
          "footer": {
            "close": true,
            "confirm": false
          }
        }
      },
      {
        "type": "feedback-confirm",
        "name": "删除能力",
        "info": "确认删除当前能力吗？删除后能力参数和能力来源会一并清理。",
        "meta": {
          "stateKey": "confirm.delete"
        },
        "action": {
          "confirm": {
            "type": "delete",
            "params": "actionTarget.deletePower"
          }
        }
      }
    ],
    "power-run-panel": [
      {
        "id": "power-stream-run",
        "type": "show-stream-request",
        "meta": {
          "powerPath": "data.actionTarget.runPower.key",
          "paramApi": "/bot/energon/power_params",
          "requestApi": "/bot/energon/request",
          "streamApi": "/bot/energon/stream",
          "blockMs": 1000,
          "uploadRules": [
            {
              "ruleId": 1,
              "kind": "image",
              "bizKey": "energon",
              "bizName": "AI生成"
            },
            {
              "ruleId": 2,
              "kind": "video",
              "bizKey": "energon",
              "bizName": "AI生成"
            },
            {
              "ruleId": 3,
              "kind": "audio",
              "bizKey": "energon",
              "bizName": "AI生成"
            },
            {
              "ruleId": 4,
              "kind": "file",
              "bizKey": "energon",
              "bizName": "AI生成"
            }
          ]
        }
      }
    ]
  },
  "data": {
    "page": {
      "description": "定义 Energon 对内对外提供的能力。"
    },
    "search": {
      "cate_id": ""
    },
    "table": {
      "page": 1,
      "pageSize": 10,
      "total": 0,
      "filterFields": [
        "cate_id"
      ]
    },
    "actionTarget": {
      "id": "",
      "deletePower": {},
      "runPower": {}
    }
  },
  "state": {
    "dialog": {
      "edit": false,
      "create": false,
      "run": false
    },
    "confirm": {
      "delete": false
    }
  },
  "action": {}
}
