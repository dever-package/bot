{
  "page": {
    "parent": "bot/energon/provider/list",
    "sort": 10
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-select",
        "value": "form.cate_id",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "来源分类不能为空。"
          }
        ]
      },
      {
        "type": "form-input",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "名称不能为空。"
          }
        ]
      },
      {
        "type": "form-radio",
        "value": "form.protocol",
        "mode": "form"
      },
      {
        "type": "form-input",
        "value": "form.host",
        "mode": "form"
      },
      {
        "type": "form-array",
        "value": "form.accounts",
        "mode": "form",
        "info": "账号随来源一起保存，调用时按排序从小到大选择开启账号。",
        "meta": {
          "pageRoute": "/bot/energon/account/update",
          "addText": "添加账号",
          "drag": "sort"
        }
      }
    ]
  },
  "data": {
    "form": {
      "cate_id": 1,
      "protocol": "openai"
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "type": "service",
        "use": "bot.energon.ProviderHook.BeforeSaveProvider"
      }
    }
  }
}
