{
  "page": {
    "name": "运行记录",
    "icon": "list-checks",
    "parent": "bot-brain",
    "sort": 2
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "className": "gap-4",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5 sm:gap-6",
        "children": {
          "toolbar-row": {
            "type": "row",
            "className": "flex-wrap items-center gap-3"
          },
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page",
        "className": "min-w-0 flex-1"
      }
    ],
    "header-actions": [],
    "toolbar-row": [
      {
        "type": "form-input",
        "placeholder": "搜索 RequestID...",
        "value": "search.keyword",
        "mode": "search"
      },
      {
        "type": "form-select",
        "placeholder": "大脑",
        "value": "search.brain_id",
        "mode": "search",
        "option": "/front/route/option?type=model&use=bot.brain.NewBrainModel&labelField=name&searchFields=name,key&pageSize=20",
        "meta": {
          "searchPlaceholder": "输入大脑名称或标识搜索..."
        }
      },
      {
        "type": "form-select",
        "placeholder": "状态",
        "value": "search.status",
        "mode": "search"
      },
      {
        "type": "form-date",
        "placeholder": "创建时间",
        "value": "search.created_at_start",
        "mode": "search",
        "className": "w-[320px]",
        "meta": {
          "range": true,
          "endValue": "search.created_at_end",
          "inputType": "datetime-local"
        }
      },
      {
        "type": "show-button",
        "name": "搜索",
        "meta": {
          "variant": "default",
          "size": "sm",
          "searchSubmit": true,
          "loadingText": "搜索中..."
        }
      },
      {
        "type": "show-button",
        "name": "重置",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "to": "/bot/brain/run/list"
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "rowKey": "id",
          "columns": [
            {
              "value": "request_id",
              "type": "show-base"
            },
            {
              "value": "brain.name",
              "name": "大脑",
              "type": "show-base"
            },
            {
              "value": "status",
              "type": "show-tag"
            },
            {
              "value": "error",
              "type": "show-base"
            },
            {
              "value": "started_at",
              "type": "show-date"
            },
            {
              "value": "finished_at",
              "type": "show-date"
            },
            {
              "value": "created_at",
              "type": "show-date"
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ]
  },
  "data": {
    "page": {
      "title": "运行记录",
      "description": "记录大脑每次执行的请求、状态、开始时间、结束时间和错误信息。"
    },
    "search": {
      "keyword": "",
      "brain_id": "",
      "status": "",
      "created_at_start": "",
      "created_at_end": ""
    },
    "table": {
      "page": 1,
      "pageSize": 10,
      "total": 0,
      "searchFields": [
        "request_id"
      ],
      "filterFields": [
        "brain_id",
        "status",
        {
          "field": "created_at",
          "type": "date-range",
          "startKey": "created_at_start",
          "endKey": "created_at_end",
          "valueType": "datetime"
        }
      ]
    }
  },
  "state": {},
  "action": {}
}
