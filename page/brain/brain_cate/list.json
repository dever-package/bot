{
  "page": {
    "parent": "bot/brain/brain/list",
    "type": 2,
    "sort": 1
  },
  "layout": {
    "type": "container",
    "children": {
      "category-shell": {
        "type": "container",
        "className": "min-w-0"
      },
      "feedback-shell": {
        "type": "container"
      }
    }
  },
  "nodes": {
    "category-shell": [
      {
        "type": "show-category-list",
        "id": "brain-cate-category",
        "value": "parent.data.search.cate_id",
        "option": "/front/route/option?type=model&use=bot.brain.NewBrainCateModel&order=sort asc,id asc",
        "meta": {
          "title": "大脑分类",
          "description": "左侧维护大脑分类",
          "remote": true,
          "defaultFirst": true,
          "createButton": {
            "name": "新增分类",
            "icon": "plus",
            "variant": "outline",
            "size": "sm",
            "action": {
              "click": {
                "type": "modal",
                "key": "dialog.create",
                "value": true
              }
            }
          },
          "buttons": [
            {
              "icon": "square-pen",
              "variant": "ghost",
              "size": "sm",
              "description": "编辑当前分类",
              "action": {
                "click": [
                  {
                    "type": "data",
                    "key": "actionTarget.id",
                    "value": "$row.id"
                  },
                  {
                    "type": "modal",
                    "key": "dialog.edit",
                    "value": true
                  }
                ]
              }
            }
          ]
        }
      }
    ],
    "feedback-shell": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.create",
          "pageRoute": "/bot/brain/brain_cate/update",
          "description": "新增后会立刻出现在左侧分类栏，并可用于大脑归类。",
          "assistant": false,
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "size": "sm",
          "bodyClassName": "py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.edit",
          "pageRoute": "/bot/brain/brain_cate/update",
          "description": "修改分类名称后，左侧分类栏和大脑编辑表单会同步显示新名称。",
          "assistant": false,
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.id"
          },
          "size": "sm",
          "bodyClassName": "py-2"
        }
      }
    ]
  },
  "data": {
    "actionTarget": {
      "id": ""
    }
  },
  "state": {
    "dialog": {
      "create": false,
      "edit": false
    }
  },
  "action": {}
}
