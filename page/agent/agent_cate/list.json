{
  "page": {
    "parent": "bot/agent/agent/list",
    "type": 2,
    "sort": 1
  },
  "layout": {
    "type": "container",
    "children": {
      "category-shell": {
        "type": "container",
        "className": "min-w-0"
      },
      "feedback-shell": {
        "type": "container"
      }
    }
  },
  "nodes": {
    "category-shell": [
      {
        "type": "show-category-list",
        "id": "agent-cate-category",
        "value": "parent.data.search.cate_id",
        "meta": {
          "title": "智能体分类",
          "description": "左侧维护智能体分类",
          "remote": true,
          "defaultFirst": true,
          "createButton": {
            "name": "新增分类",
            "icon": "plus",
            "variant": "outline",
            "size": "sm",
            "action": {
              "click": {
                "type": "modal",
                "key": "dialog.create",
                "value": true
              }
            }
          },
          "buttons": [
            {
              "icon": "square-pen",
              "variant": "ghost",
              "size": "sm",
              "description": "编辑当前分类",
              "action": {
                "click": [
                  {
                    "type": "data",
                    "key": "actionTarget.id",
                    "value": "$row.id"
                  },
                  {
                    "type": "modal",
                    "key": "dialog.edit",
                    "value": true
                  }
                ]
              }
            }
          ]
        }
      }
    ],
    "feedback-shell": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.create",
          "pageRoute": "/bot/agent/agent_cate/update",
          "description": "新增后会立刻出现在左侧分类栏，并可用于智能体归类。",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "size": "sm",
          "bodyClassName": "py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.edit",
          "pageRoute": "/bot/agent/agent_cate/update",
          "description": "修改分类名称后，左侧分类栏和智能体编辑表单会同步更新。",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.id"
          },
          "size": "sm",
          "bodyClassName": "py-2"
        }
      }
    ]
  },
  "data": {
    "actionTarget": {
      "id": ""
    }
  },
  "state": {
    "dialog": {
      "create": false,
      "edit": false
    }
  },
  "action": {}
}
