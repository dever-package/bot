{
  "page": {
    "parent": "bot/agent/agent/list",
    "type": 2,
    "sort": 9
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "placeholder": "例如：小说智能体",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "分类名称不能为空。"
          },
          {
            "type": "model",
            "except": "$form.id",
            "message": "该分类名称已存在，请更换。"
          }
        ]
      },
      {
        "type": "form-number",
        "value": "form.sort",
        "mode": "form"
      }
    ]
  },
  "data": {
    "form": {
      "sort": 100
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form"
    }
  }
}
