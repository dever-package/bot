{
  "page": {
    "name": "方案编辑",
    "parent": "bot/agent/setting_pack/list",
    "type": 2,
    "sort": 10,
    "auth": [
      {
        "key": "bot/agent/setting_pack/create",
        "name": "方案新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "bot/agent/setting_pack/update",
        "name": "方案编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "placeholder": "例如：默认通用协议",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "方案名称不能为空。"
          },
          {
            "type": "model",
            "except": "$form.id",
            "message": "该方案名称已存在。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-textarea",
        "placeholder": "描述这个方案适合哪些智能体或场景。",
        "value": "form.description",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "rows": 3
        }
      },
      {
        "type": "form-array",
        "name": "设定",
        "value": "form.items",
        "mode": "form",
        "info": "设定列表：选择通用设定组成当前方案；运行时会按这里的排序加载。",
        "meta": {
          "formLayout": "horizontal",
          "pageRoute": "/bot/agent/setting_pack_item/update",
          "addText": "添加设定",
          "drag": "sort"
        }
      }
    ]
  },
  "data": {
    "form": {
      "name": "",
      "description": "",
      "items": [],
      "status": 1,
      "sort": 100
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "type": "service",
        "use": "bot.agent.AgentHook.BeforeSaveSettingPack"
      }
    }
  }
}
