{
  "page": {
    "name": "智能体编辑",
    "parent": "bot/agent/agent/list",
    "type": 2,
    "sort": 10,
    "auth": [
      {
        "key": "bot/agent/agent/create",
        "name": "智能体新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "bot/agent/agent/update",
        "name": "智能体编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-select",
        "value": "form.cate_id",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "智能体分类不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[260px]"
        }
      },
      {
        "type": "form-input",
        "placeholder": "例如：图生图智能体",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "智能体名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "placeholder": "例如：image-to-image-agent",
        "value": "form.key",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "智能体标识不能为空。"
          },
          {
            "type": "model",
            "except": "$form.id",
            "message": "该智能体标识已存在。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-textarea",
        "placeholder": "描述这个智能体负责什么事情。",
        "value": "form.description",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "rows": 3
        }
      },
      {
        "type": "form-select",
        "placeholder": "请选择 Energon 中的 LLM 能力",
        "value": "form.llm_power_id",
        "mode": "form",
        "option": "/front/route/option?type=service&use=bot.agent.OptionService.LoadTextPowers",
        "info": "第一阶段 Agent 直接通过这个 LLM 能力调用 Energon。",
        "validate": [
          {
            "type": "required",
            "message": "LLM能力不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[360px]"
        }
      },
      {
        "type": "form-select",
        "name": "执行方案",
        "placeholder": "请选择执行方案",
        "value": "form.setting_pack_id",
        "mode": "form",
        "option": "/front/route/option?type=model&use=bot.agent.NewSettingPackModel&filterField=status&filterValue=1&order=sort asc,id asc",
        "info": "运行和测试时加载这个方案下的通用设定，再加载智能体设定。",
        "validate": [
          {
            "type": "required",
            "message": "执行方案不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[260px]"
        }
      },
      {
        "type": "form-number",
        "placeholder": "0-2，建议 0.2-1.0",
        "value": "form.temperature",
        "mode": "form",
        "info": "控制 LLM 输出随机性。0 更稳定、2 更发散；默认 0.7，通常不要超过 1。",
        "validate": [
          {
            "type": "min",
            "min": 0,
            "message": "温度不能小于 0。"
          },
          {
            "type": "max",
            "max": 2,
            "message": "温度不能大于 2。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[160px]"
        }
      },
      {
        "type": "form-number",
        "placeholder": "单位：秒，10-3600",
        "value": "form.timeout_seconds",
        "mode": "form",
        "info": "单次运行的总超时时间，单位是秒。超过后运行应停止并记录失败/超时，默认 300 秒。",
        "validate": [
          {
            "type": "min",
            "min": 10,
            "message": "超时时间不能小于 10 秒。"
          },
          {
            "type": "max",
            "max": 3600,
            "message": "超时时间不能大于 3600 秒。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[160px]"
        }
      }
    ]
  },
  "data": {
    "form": {
      "cate_id": 1,
      "name": "",
      "key": "",
      "description": "",
      "llm_power_id": "",
      "setting_pack_id": 1,
      "temperature": 0.7,
      "timeout_seconds": 300
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "type": "service",
        "use": "bot.agent.AgentHook.BeforeSaveAgent"
      }
    }
  }
}
