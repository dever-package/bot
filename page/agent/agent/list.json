{
  "page": {
    "name": "智能体",
    "icon": "bot",
    "parent": "bot-agent",
    "sort": 1
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "className": "gap-4",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5 sm:gap-6",
        "children": {
          "content-shell": {
            "type": "container",
            "className": "front-two-pane-layout",
            "children": {
              "category-column": {
                "type": "container",
                "className": "min-w-0",
                "path": "/bot/agent/agent_cate/list",
                "meta": {
                  "updateDocumentTitle": false
                }
              },
              "list-column": {
                "type": "container",
                "className": "flex min-w-0 flex-col gap-4",
                "children": {
                  "table-row": {
                    "type": "container",
                    "className": "overflow-hidden rounded-md border bg-background"
                  }
                }
              }
            }
          },
          "feedback-shell": {
            "type": "container"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page",
        "className": "min-w-0 flex-1"
      }
    ],
    "header-actions": [
      {
        "type": "show-button",
        "name": "新增智能体",
        "className": "shrink-0",
        "meta": {
          "variant": "default",
          "size": "sm"
        },
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.create",
            "value": true
          }
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "savePath": "bot/agent/agent/update",
          "rowKey": "id",
          "columns": [
            {
              "value": "name",
              "type": "show-base"
            },
            {
              "value": "key",
              "type": "show-base"
            },
            {
              "value": "llm_power.name",
              "name": "LLM能力",
              "type": "show-base"
            },
            {
              "value": "setting_pack.name",
              "name": "执行方案",
              "type": "show-base"
            },
            {
              "value": "status",
              "type": "form-switch",
              "meta": {
                "trueValue": 1,
                "falseValue": 2
              }
            },
            {
              "value": "sort",
              "type": "show-base",
              "editor": "form-number",
              "trigger": "doubleClick",
              "tip": "正序排序，数值越大越靠后。双击可修改。"
            },
            {
              "value": "created_at",
              "type": "show-date"
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "square-pen",
                    "variant": "outline",
                    "size": "sm",
                    "description": "编辑智能体",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.editAgentId",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.edit",
                          "value": true
                        }
                      ]
                    }
                  },
                  {
                    "icon": "file-text",
                    "variant": "outline",
                    "size": "sm",
                    "description": "设定",
                    "to": "/bot/agent/agent_setting/list",
                    "searchParam": "id",
                    "searchField": "id",
                    "withBack": true
                  },
                  {
                    "icon": "book-open",
                    "variant": "outline",
                    "size": "sm",
                    "description": "资料",
                    "to": "/bot/agent/agent_knowledge/list",
                    "searchParam": "agent_id",
                    "searchField": "id",
                    "withBack": true
                  },
                  {
                    "icon": "message-circle",
                    "variant": "outline",
                    "size": "sm",
                    "description": "测试智能体",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.testAgent",
                          "value": "$row"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.test",
                          "value": true
                        }
                      ]
                    }
                  },
                  {
                    "icon": "trash-2",
                    "variant": "outline",
                    "size": "sm",
                    "description": "删除智能体",
                    "className": "text-destructive hover:text-destructive",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.deleteAgent",
                          "value": "$row"
                        },
                        {
                          "type": "modal",
                          "key": "confirm.delete",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "feedback-shell": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.edit",
          "pageRoute": "/bot/agent/agent/update",
          "description": "配置智能体 LLM 能力和通用规则方案。",
          "size": "xl",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.editAgentId"
          }
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.create",
          "pageRoute": "/bot/agent/agent/update",
          "description": "创建智能体后，运行时会基于方案、智能体设定和 Energon 能力执行。",
          "size": "xl",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "cate_id": "data.search.cate_id"
          }
        }
      },
      {
        "type": "feedback-modal",
        "name": "测试智能体",
        "info": "当前弹窗内保留临时上下文，关闭后会重新开始新对话。",
        "meta": {
          "stateKey": "dialog.test",
          "formSection": "agent-panel",
          "titleNamePath": "data.actionTarget.testAgent.name",
          "titleKeyPath": "data.actionTarget.testAgent.key",
          "size": "3xl",
          "bodyScroll": false,
          "footer": {
            "close": false,
            "confirm": false
          }
        }
      },
      {
        "type": "feedback-confirm",
        "name": "删除智能体",
        "info": "确认删除当前智能体吗？已产生的运行记录不会自动删除。",
        "meta": {
          "stateKey": "confirm.delete"
        },
        "action": {
          "confirm": {
            "type": "delete",
            "params": "actionTarget.deleteAgent"
          }
        }
      }
    ],
    "agent-panel": [
      {
        "id": "agent-stream",
        "type": "show-agent",
        "meta": {
          "agentPath": "data.actionTarget.testAgent.key",
          "agentNamePath": "data.actionTarget.testAgent.name",
          "openPath": "state.dialog.test",
          "requestApi": "/bot/agent/run",
          "streamApi": "/bot/agent/stream",
          "stopApi": "/bot/agent/stop",
          "paramApi": "/bot/energon/power_params",
          "blockMs": 1000
        }
      }
    ]
  },
  "data": {
    "page": {
      "title": "智能体",
      "description": "维护智能体基础设定。运行时会追加智能体设定、能力、skills 和临时上下文。"
    },
    "table": {
      "page": 1,
      "pageSize": 10,
      "total": 0,
      "filterFields": [
        "cate_id"
      ]
    },
    "search": {
      "cate_id": ""
    },
    "actionTarget": {
      "editAgentId": "",
      "deleteAgent": {},
      "testAgent": {}
    }
  },
  "state": {
    "dialog": {
      "edit": false,
      "create": false,
      "test": false
    },
    "confirm": {
      "delete": false
    }
  },
  "action": {}
}
