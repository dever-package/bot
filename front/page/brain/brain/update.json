{
  "page": {
    "name": "大脑编辑",
    "parent": "bot/brain/brain/list",
    "type": 2,
    "auth": [
      {
        "key": "bot/brain/brain/create",
        "name": "大脑新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "bot/brain/brain/update",
        "name": "大脑编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-select",
        "name": "大脑分类",
        "value": "form.cate_id",
        "mode": "form",
        "option": "/front/route/option?type=model&use=bot.brain.NewBrainCateModel&order=sort asc,id asc",
        "validate": [
          {
            "type": "required",
            "message": "大脑分类不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[260px]"
        }
      },
      {
        "type": "form-input",
        "placeholder": "例如：内容运营大脑",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "大脑名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "placeholder": "例如：content-brain",
        "value": "form.key",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "大脑标识不能为空。"
          },
          {
            "type": "model",
            "except": "$form.id",
            "message": "该大脑标识已存在。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-textarea",
        "placeholder": "描述这个大脑负责什么任务。",
        "value": "form.description",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "rows": 3
        }
      },
      {
        "type": "form-textarea",
        "placeholder": "描述这个大脑的角色、口吻和工作边界。",
        "value": "form.persona",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "rows": 4
        }
      },
      {
        "type": "form-textarea",
        "placeholder": "描述这个大脑要达成的目标。",
        "value": "form.goal",
        "mode": "form",
        "meta": {
          "formLayout": "horizontal",
          "rows": 4
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": 0,
      "cate_id": 1,
      "name": "",
      "key": "",
      "description": "",
      "persona": "",
      "goal": ""
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "type": "service",
        "use": "bot.brain.BrainHook.BeforeSaveBrain"
      }
    }
  }
}
