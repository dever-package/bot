{
  "page": {
    "name": "画布能力",
    "parent": "bot/body/canvas_power/list",
    "type": 2,
    "auth": [
      {
        "key": "bot/body/canvas_power/create",
        "name": "画布能力新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "bot/body/canvas_power/update",
        "name": "画布能力编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-cascader",
        "name": "能力",
        "value": "form.power_id",
        "mode": "form",
        "placeholder": "请选择能力",
        "validate": [
          {
            "type": "required",
            "message": "能力不能为空。"
          }
        ],
        "meta": {
          "api": "/front/route/option",
          "use": "bot.energon.NewPowerCateModel",
          "childUse": "bot.energon.NewPowerModel",
          "childParentField": "cate_id",
          "valueMode": "leaf",
          "placeholder": [
            "选择能力分类",
            "选择能力"
          ],
          "childExtraFields": "key,kind,cate_id,status"
        }
      },
      {
        "type": "form-switch",
        "name": "状态",
        "value": "form.status",
        "mode": "form",
        "meta": {
          "trueValue": 1,
          "falseValue": 2
        }
      }
    ]
  },
  "data": {
    "form": {
      "canvas_id": 0,
      "power_id": 0,
      "config": "{}",
      "status": 1
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form"
    }
  }
}
