{
  "page": {
    "name": "画布编辑",
    "parent": "bot/body/canvas/list",
    "type": 2,
    "auth": [
      {
        "key": "bot/body/canvas/create",
        "name": "画布新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "bot/body/canvas/update",
        "name": "画布编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "name": "名称",
        "placeholder": "例如：默认自由画布",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": 0,
      "name": "",
      "config": "{}",
      "status": 1
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "type": "service",
        "use": "bot.body.CanvasHook.BeforeSaveCanvas"
      }
    }
  }
}
