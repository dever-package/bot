{
  "page": {
    "name": "运行记录",
    "icon": "list-checks",
    "parent": "bot-team",
    "sort": 2
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "className": "gap-4",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5 sm:gap-6",
        "children": {
          "toolbar-row": {
            "type": "row",
            "className": "flex-wrap items-center gap-3"
          },
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          },
          "feedback-shell": {
            "type": "container"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page",
        "className": "min-w-0 flex-1"
      }
    ],
    "header-actions": [],
    "toolbar-row": [
      {
        "type": "form-input",
        "placeholder": "搜索 RequestID...",
        "value": "search.keyword",
        "mode": "search"
      },
      {
        "type": "form-select",
        "placeholder": "团队",
        "value": "search.team_id",
        "mode": "search",
        "option": {
          "model": "bot.team.NewTeamModel",
          "labelField": "name",
          "searchFields": [
            "name"
          ],
          "pageSize": 20
        },
        "meta": {
          "searchPlaceholder": "输入团队名称搜索..."
        }
      },
      {
        "type": "form-select",
        "placeholder": "状态",
        "value": "search.status",
        "mode": "search"
      },
      {
        "type": "form-date",
        "placeholder": "创建时间",
        "value": "search.created_at_start",
        "mode": "search",
        "meta": {
          "searchWidth": "select",
          "range": true,
          "endValue": "search.created_at_end",
          "inputType": "datetime-local"
        }
      },
      {
        "type": "show-button",
        "name": "搜索",
        "meta": {
          "variant": "default",
          "size": "sm",
          "searchSubmit": true,
          "loadingText": "搜索中..."
        }
      },
      {
        "type": "show-button",
        "name": "重置",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "to": "/bot/team/run/list"
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "rowKey": "id",
          "columns": [
            {
              "value": "request_id",
              "type": "show-base"
            },
            {
              "value": "team.name",
              "name": "团队",
              "type": "show-base"
            },
            {
              "value": "status",
              "type": "show-tag"
            },
            {
              "value": "started_at",
              "type": "show-date"
            },
            {
              "value": "finished_at",
              "type": "show-date"
            },
            {
              "value": "created_at",
              "type": "show-date"
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "eye",
                    "variant": "outline",
                    "size": "sm",
                    "description": "查看运行详情",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.viewRunId",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.view",
                          "value": true
                        }
                      ]
                    }
                  },
                  {
                    "icon": "list-tree",
                    "variant": "outline",
                    "size": "sm",
                    "description": "查看运行步骤",
                    "to": "/bot/team/node_run/list",
                    "searchParam": "run_id",
                    "searchField": "id",
                    "withBack": true
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "feedback-shell": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.view",
          "pageRoute": "/bot/team/run/view",
          "description": "查看本次团队运行输入、输出与错误信息。",
          "size": "xl",
          "bodyClassName": "max-h-[65vh] overflow-y-auto px-6 py-2",
          "pageRouteQuery": {
            "id": "data.actionTarget.viewRunId"
          }
        }
      }
    ]
  },
  "data": {
    "page": {
      "title": "运行记录",
      "description": "记录团队每次执行的请求、状态、开始时间和结束时间。"
    },
    "search": {
      "keyword": "",
      "team_id": "",
      "status": "",
      "created_at_start": "",
      "created_at_end": ""
    },
    "table": {
      "searchFields": [
        "request_id"
      ],
      "filterFields": [
        "team_id",
        "status",
        {
          "field": "created_at",
          "type": "date-range",
          "startKey": "created_at_start",
          "endKey": "created_at_end",
          "valueType": "datetime"
        }
      ]
    },
    "actionTarget": {
      "viewRunId": ""
    }
  },
  "state": {
    "dialog": {
      "view": false
    }
  },
  "action": {}
}
