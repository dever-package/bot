{
  "page": {
    "name": "团队能力",
    "parent": "bot/team/team_power/list",
    "type": 2,
    "auth": [
      {
        "key": "bot/team/team_power/create",
        "name": "团队能力新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "bot/team/team_power/update",
        "name": "团队能力编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-cascader",
        "name": "能力",
        "value": "form.power_id",
        "mode": "form",
        "placeholder": "请选择能力",
        "validate": [
          {
            "type": "required",
            "message": "能力不能为空。"
          }
        ],
        "meta": {
          "childParentField": "cate_id",
          "valueMode": "leaf",
          "placeholder": [
            "选择能力分类",
            "选择能力"
          ],
          "childExtraFields": "key,kind,cate_id,status",
          "formLayout": "horizontal",
          "searchPlaceholder": "输入能力名称搜索...",
          "model": "bot.energon.NewPowerCateModel",
          "childModel": "bot.energon.NewPowerModel"
        }
      },
      {
        "type": "form-switch",
        "name": "状态",
        "value": "form.status",
        "mode": "form",
        "meta": {
          "trueValue": 1,
          "falseValue": 2,
          "formLayout": "horizontal"
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": 0,
      "team_id": 0,
      "power_id": 0,
      "config": "{}",
      "status": 1,
      "sort": 100
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "bot.team.TeamHook.BeforeSaveTeamPower"
      }
    }
  }
}
