{
  "page": {
    "name": "团队能力",
    "icon": "sparkles",
    "parent": "bot/team/team/list",
    "type": 2
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "className": "gap-4",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5 sm:gap-6",
        "children": {
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          },
          "feedback-shell": {
            "type": "container"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page",
        "className": "min-w-0 flex-1"
      }
    ],
    "header-actions": [
      {
        "type": "show-button",
        "name": "返回团队列表",
        "className": "shrink-0",
        "meta": {
          "icon": "arrow-left",
          "variant": "outline",
          "size": "sm",
          "to": "/bot/team/team/list"
        }
      },
      {
        "type": "show-button",
        "name": "新增能力",
        "meta": {
          "variant": "default",
          "size": "sm"
        },
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.create",
            "value": true
          }
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "savePath": "bot/team/team_power/update",
          "rowKey": "id",
          "columns": [
            {
              "value": "team.name",
              "name": "团队",
              "type": "show-base"
            },
            {
              "value": "power.name",
              "name": "能力",
              "type": "show-base"
            },
            {
              "value": "power.kind",
              "name": "能力类型",
              "type": "show-base"
            },
            {
              "value": "status",
              "type": "form-switch",
              "meta": {
                "trueValue": 1,
                "falseValue": 2
              }
            },
            {
              "value": "sort",
              "type": "show-base",
              "editor": "form-number",
              "trigger": "doubleClick"
            },
            {
              "value": "created_at",
              "type": "show-date"
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "square-pen",
                    "variant": "outline",
                    "size": "sm",
                    "description": "编辑",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.editTeamPowerId",
                          "value": "$row.id"
                        },
                        {
                          "type": "data",
                          "key": "actionTarget.editTeamId",
                          "value": "$row.team_id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.edit",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "feedback-shell": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.create",
          "pageRoute": "/bot/team/team_power/update",
          "title": "新增团队能力",
          "description": "选择当前团队可在流程和作品画布中使用的能力。未配置任何能力时表示不限制能力。",
          "size": "lg",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "team_id": "data.search.team_id"
          },
          "pageDataPatches": {
            "form.team_id": "data.search.team_id"
          },
          "bodyClassName": "px-6 py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.edit",
          "pageRoute": "/bot/team/team_power/update",
          "title": "编辑团队能力",
          "size": "lg",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.editTeamPowerId",
            "team_id": "data.actionTarget.editTeamId"
          },
          "pageDataPatches": {
            "form.team_id": "data.actionTarget.editTeamId"
          },
          "bodyClassName": "px-6 py-2"
        }
      }
    ]
  },
  "data": {
    "page": {
      "title": "团队能力",
      "description": "维护团队允许使用的能力。为空时表示该团队不限制能力。"
    },
    "search": {
      "team_id": ""
    },
    "table": {
      "page": 1,
      "pageSize": 10,
      "total": 0,
      "filterFields": ["team_id"]
    },
    "actionTarget": {
      "editTeamPowerId": "",
      "editTeamId": ""
    }
  },
  "state": {
    "dialog": {
      "create": false,
      "edit": false
    }
  },
  "action": {}
}
