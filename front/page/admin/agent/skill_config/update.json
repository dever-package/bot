{
  "page": {
    "parent": "bot/agent/skill_config/list",
    "type": 2,
    "sort": 1,
    "auth": [
      {
        "key": "bot/agent/skill_config/create",
        "name": "环境变量新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "bot/agent/skill_config/update",
        "name": "环境变量编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "name": "变量名称",
        "placeholder": "例如：微信公众号 Cookie",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "变量名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "name": "变量标识",
        "placeholder": "例如：WECHAT_COOKIE",
        "value": "form.key",
        "mode": "form",
        "info": "运行技能脚本时会按这个标识原样注入环境变量；只允许字母、数字和下划线，不会自动改名。",
        "validate": [
          {
            "type": "required",
            "message": "变量标识不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-radio",
        "name": "变量类型",
        "value": "form.type",
        "mode": "form",
        "info": "明文类型会直接保存并展示；加密类型会加密保存，只显示是否已填写。",
        "validate": [
          {
            "type": "required",
            "message": "变量类型不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[260px]"
        }
      },
      {
        "type": "form-textarea",
        "name": "变量值",
        "placeholder": "编辑时留空表示保留已有值",
        "value": "form.value_plain",
        "mode": "form",
        "info": "明文类型会在列表中展示真实值；加密类型只展示已填写，运行日志会尽量脱敏。",
        "validate": [
          {
            "type": "required",
            "message": "变量值不能为空。",
            "when": [
              {
                "path": "form.id",
                "operator": "empty"
              }
            ]
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "rows": 5
        }
      }
    ]
  },
  "data": {
    "form": {
      "model": "bot.agent.NewSkillConfigModel",
      "service": "bot.agent.setting.AgentHook.AttachSkillConfigForm",
      "id": 0,
      "skill_id": 0,
      "key": "",
      "name": "",
      "type": "text",
      "value_plain": ""
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "model": "bot.agent.NewSkillConfigModel",
      "params": "form",
      "before": {
        "service": "bot.agent.setting.AgentHook.BeforeSaveSkillConfig"
      }
    }
  }
}
