{
  "page": {
    "name": "环境变量",
    "parent": "bot/agent/skill_pack/list",
    "type": 2,
    "sort": 12
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0 space-y-4",
        "children": {
          "header-row": {
            "type": "container",
            "className": "flex justify-end"
          },
          "table-row": {
            "type": "container",
            "className": "space-y-3"
          },
          "feedback-shell": {
            "type": "container"
          }
        }
      }
    }
  },
  "nodes": {
    "header-row": [
      {
        "type": "show-button",
        "name": "新增环境变量",
        "className": "shrink-0",
        "meta": {
          "variant": "default",
          "size": "sm",
          "icon": "plus"
        },
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.create",
            "value": true
          }
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "savePath": "bot/agent/skill_config/update",
          "rowKey": "id",
          "columns": [
            {
              "value": "name",
              "name": "变量名称",
              "type": "show-base"
            },
            {
              "value": "key",
              "name": "变量标识",
              "type": "show-base"
            },
            {
              "value": "type",
              "name": "变量类型",
              "type": "show-tag"
            },
            {
              "value": "value_hint",
              "name": "变量值",
              "type": "show-base",
              "className": "w-[360px] max-w-[360px] overflow-hidden text-ellipsis whitespace-nowrap [&>div]:block [&>div]:truncate [&_span]:truncate"
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "square-pen",
                    "variant": "outline",
                    "size": "sm",
                    "description": "编辑环境变量",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.id",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.edit",
                          "value": true
                        }
                      ]
                    }
                  },
                  {
                    "icon": "trash-2",
                    "variant": "outline",
                    "size": "sm",
                    "description": "删除环境变量",
                    "className": "text-destructive hover:text-destructive",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.deleteConfig",
                          "value": "$row"
                        },
                        {
                          "type": "modal",
                          "key": "confirm.delete",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "feedback-shell": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.create",
          "pageRoute": "/bot/agent/skill_config/update",
          "title": "新增环境变量",
          "description": "技能选择该变量后，运行脚本时按变量标识注入环境变量；明文类型会展示真实值，加密类型只展示已填写。",
          "assistant": false,
          "pageRouteQuery": {
            "skill_id": "data.search.skill_id"
          },
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "size": "lg",
          "bodyClassName": "px-6 py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.edit",
          "pageRoute": "/bot/agent/skill_config/update",
          "title": "编辑环境变量",
          "description": "变量值留空时保留旧值，不会清空已有变量。",
          "assistant": false,
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.id",
            "skill_id": "data.search.skill_id"
          },
          "size": "lg",
          "bodyClassName": "px-6 py-2"
        }
      },
      {
        "type": "feedback-confirm",
        "name": "删除环境变量",
        "info": "确认删除当前环境变量吗？删除后已绑定该变量的技能运行时将不再注入这个环境变量。",
        "meta": {
          "stateKey": "confirm.delete"
        },
        "action": {
          "confirm": {
            "type": "delete",
            "model": "bot.agent.NewSkillConfigModel",
            "params": "actionTarget.deleteConfig",
            "before": {
              "service": "bot.agent.setting.AgentHook.BeforeDeleteSkillConfig"
            }
          }
        }
      }
    ]
  },
  "data": {
    "page": {
      "title": "环境变量",
      "description": "维护当前技能脚本运行时可注入的环境变量；变量不会写入 prompt 或 manifest，加密类型会隐藏展示。"
    },
    "search": {
      "skill_id": ""
    },
    "table": {
      "searchFields": [
        "name",
        "key"
      ],
      "filterFields": [
        "skill_id"
      ],
      "defaultFilters": {
        "skill_id": 0
      },
      "model": "bot.agent.NewSkillConfigModel",
      "service": "bot.agent.setting.AgentHook.AttachSkillConfigList"
    },
    "actionTarget": {
      "id": "",
      "deleteConfig": {}
    }
  },
  "state": {
    "dialog": {
      "create": false,
      "edit": false
    },
    "confirm": {
      "delete": false
    }
  },
  "action": {}
}
