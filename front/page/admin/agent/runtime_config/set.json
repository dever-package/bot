{
  "page": {
    "name": "智能体运行配置",
    "parent": "bot/agent/agent/list",
    "type": 2,
    "sort": 20,
    "auth": [
      {
        "key": "bot/agent/runtime_config/set",
        "name": "智能体运行配置",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "tabs-row": {
            "type": "container",
            "className": "mb-4"
          },
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "tabs-row": [
      {
        "type": "nav-tab",
        "meta": {
          "target": "state.currentTab",
          "variant": "line",
          "tabs": [
            {
              "label": "基础配置",
              "value": "basic"
            },
            {
              "label": "技能配置",
              "value": "skill"
            },
            {
              "label": "运行沙箱",
              "value": "sandbox"
            }
          ]
        }
      }
    ],
    "dialog-shell": [
      {
        "type": "form-number",
        "name": "默认最大自动步骤数",
        "placeholder": "例如：5",
        "value": "form.default_max_auto_steps",
        "mode": "form",
        "info": "智能体未单独设置最大自动步骤数时使用这个值。",
        "validate": [
          {
            "type": "min",
            "min": 1,
            "message": "默认最大自动步骤数不能小于 1。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "tab": "basic",
          "controlClassName": "max-w-[160px]"
        }
      },
      {
        "type": "form-number",
        "name": "强制最大自动步骤数",
        "placeholder": "例如：8",
        "value": "form.hard_max_auto_steps",
        "mode": "form",
        "info": "所有智能体实际自动执行步骤都不会超过这个值。",
        "validate": [
          {
            "type": "min",
            "min": 1,
            "message": "全局强制最大自动步骤数不能小于 1。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "tab": "basic",
          "controlClassName": "max-w-[160px]"
        }
      },
      {
        "type": "form-number",
        "name": "技能 metadata 最大技能数",
        "placeholder": "例如：80",
        "value": "form.skill_metadata_max_skills",
        "mode": "form",
        "info": "运行时最多向模型注入多少个技能 metadata；超过后只注入前 N 个。",
        "validate": [
          {
            "type": "min",
            "min": 1,
            "message": "技能 metadata 最大技能数不能小于 1。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "tab": "skill",
          "controlClassName": "max-w-[160px]"
        }
      },
      {
        "type": "form-number",
        "name": "metadata 单字段最大长度",
        "placeholder": "例如：240",
        "value": "form.skill_metadata_field_max_length",
        "mode": "form",
        "info": "技能名称、描述、触发词等 metadata 单字段的最大字符数。",
        "validate": [
          {
            "type": "min",
            "min": 1,
            "message": "metadata 单字段最大长度不能小于 1。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "tab": "skill",
          "controlClassName": "max-w-[160px]"
        }
      },
      {
        "type": "form-number",
        "name": "SKILL.md 最大读取字节数",
        "placeholder": "例如：262144",
        "value": "form.skill_file_max_bytes",
        "mode": "form",
        "info": "单个 SKILL.md 运行时最多读取的字节数；256KB = 262144 字节。",
        "validate": [
          {
            "type": "min",
            "min": 1,
            "message": "SKILL.md 最大读取字节数不能小于 1。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "tab": "skill",
          "controlClassName": "max-w-[180px]"
        }
      },
      {
        "type": "form-number",
        "name": "本轮技能正文最大总长度",
        "placeholder": "例如：30000",
        "value": "form.skill_loaded_content_max_length",
        "mode": "form",
        "info": "本轮按需加载的多个技能正文合计最大字符数。",
        "validate": [
          {
            "type": "min",
            "min": 1,
            "message": "本轮技能正文最大总长度不能小于 1。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "tab": "skill",
          "controlClassName": "max-w-[160px]"
        }
      },
      {
        "id": "runtime-script-sandbox-driver",
        "type": "form-radio",
        "name": "脚本沙箱模式",
        "placeholder": "请选择脚本沙箱模式",
        "value": "form.script_sandbox_driver",
        "mode": "form",
        "option": [
          {
            "id": "disabled",
            "value": "禁用脚本"
          },
          {
            "id": "local",
            "value": "本地受控执行"
          },
          {
            "id": "bwrap",
            "value": "bubblewrap 沙箱"
          }
        ],
        "info": "控制 run_skill_script 如何执行技能 scripts/ 下的脚本。生产环境建议使用 bubblewrap 沙箱；不会自动降级到本地执行。",
        "validate": [
          {
            "type": "required",
            "message": "脚本沙箱模式不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "tab": "sandbox",
          "controlClassName": "max-w-[520px]",
          "control": [
            {
              "value": "disabled",
              "hide": [
                "runtime-script-sandbox-network-mode",
                "runtime-script-sandbox-timeout",
                "runtime-script-sandbox-output"
              ]
            },
            {
              "value": "local",
              "hide": [
                "runtime-script-sandbox-network-mode"
              ]
            }
          ]
        }
      },
      {
        "id": "runtime-script-sandbox-network-mode",
        "type": "form-radio",
        "name": "脚本网络",
        "placeholder": "请选择脚本网络模式",
        "value": "form.script_sandbox_network_mode",
        "mode": "form",
        "option": [
          {
            "id": "host",
            "value": "使用宿主网络"
          },
          {
            "id": "none",
            "value": "断网"
          }
        ],
        "info": "默认使用宿主网络。需要严格隔离时可切换为断网。",
        "validate": [
          {
            "type": "required",
            "message": "脚本网络模式不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "tab": "sandbox",
          "controlClassName": "max-w-[360px]"
        }
      },
      {
        "id": "runtime-script-sandbox-timeout",
        "type": "form-number",
        "name": "脚本超时时间",
        "placeholder": "单位：秒，1-60",
        "value": "form.script_sandbox_timeout_seconds",
        "mode": "form",
        "info": "run_skill_script 的默认超时时间；模型单次调用可传 timeout_seconds，但不会超过这里和系统上限。",
        "validate": [
          {
            "type": "min",
            "min": 1,
            "message": "脚本超时时间不能小于 1 秒。"
          },
          {
            "type": "max",
            "max": 60,
            "message": "脚本超时时间不能超过 60 秒。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "tab": "sandbox",
          "controlClassName": "max-w-[160px]"
        }
      },
      {
        "id": "runtime-script-sandbox-output",
        "type": "form-number",
        "name": "脚本输出最大字节数",
        "placeholder": "例如：262144",
        "value": "form.script_sandbox_output_max_bytes",
        "mode": "form",
        "info": "stdout 和 stderr 各自最多保留的字节数；超出会截断，避免大输出撑爆上下文。",
        "validate": [
          {
            "type": "min",
            "min": 1,
            "message": "脚本输出最大字节数不能小于 1。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "tab": "sandbox",
          "controlClassName": "max-w-[180px]"
        }
      },
      {
        "type": "show-text",
        "name": "安装指引",
        "value": "sandbox_install_guide",
        "mode": "form",
        "className": "whitespace-pre-wrap break-words rounded-md border bg-muted/30 p-3 font-mono text-xs text-foreground",
        "meta": {
          "formLayout": "horizontal",
          "tab": "sandbox"
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": 1,
      "default_max_auto_steps": 5,
      "hard_max_auto_steps": 8,
      "skill_metadata_max_skills": 80,
      "skill_metadata_field_max_length": 1000,
      "skill_file_max_bytes": 262144,
      "skill_loaded_content_max_length": 30000,
      "script_sandbox_driver": "bwrap",
      "script_sandbox_bwrap_path": "bwrap",
      "script_sandbox_network_mode": "host",
      "script_sandbox_timeout_seconds": 15,
      "script_sandbox_output_max_bytes": 262144,
      "model": "bot.agent.NewRuntimeConfigModel"
    },
    "sandbox_install_guide": "bubblewrap 不是 Linux 自带命令，需要部署时安装。\nDebian / Ubuntu：apt-get update && apt-get install -y bubblewrap\nCentOS / RHEL / Fedora：dnf install -y bubblewrap 或 yum install -y bubblewrap\nAlpine：apk add --no-cache bubblewrap\n检测命令：which bwrap && bwrap --version"
  },
  "state": {
    "currentTab": "basic"
  },
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "bot.agent.setting.AgentHook.BeforeSaveRuntimeConfig"
      },
      "model": "bot.agent.NewRuntimeConfigModel"
    }
  }
}
