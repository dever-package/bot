{
  "page": {
    "name": "技能详情",
    "parent": "bot/agent/skill_pack/list",
    "type": 2,
    "sort": 11
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "detail-shell": {
            "type": "container",
            "className": "space-y-4 rounded-lg border bg-background p-4"
          }
        }
      }
    }
  },
  "nodes": {
    "detail-shell": [
      {
        "type": "show-title",
        "value": "form.name"
      },
      {
        "type": "show-base",
        "value": "form.description",
        "className": "text-sm text-muted-foreground whitespace-pre-wrap break-words"
      },
      {
        "type": "show-title",
        "value": "page.installTitle",
        "meta": {
          "variant": "section",
          "hiddenWhen": [
            {
              "path": "form.has_install_info",
              "operator": "equals",
              "value": false
            }
          ]
        }
      },
      {
        "type": "show-base",
        "value": "form.source_url",
        "className": "rounded-md border bg-muted/30 p-3 text-sm break-all",
        "meta": {
          "hiddenWhen": [
            {
              "path": "form.has_source_url",
              "operator": "equals",
              "value": false
            }
          ]
        }
      },
      {
        "type": "show-base",
        "value": "form.install_input",
        "className": "rounded-md border bg-muted/30 p-3 text-sm leading-6 whitespace-pre-wrap break-words",
        "meta": {
          "hiddenWhen": [
            {
              "path": "form.has_install_input",
              "operator": "equals",
              "value": false
            }
          ]
        }
      },
      {
        "type": "show-base",
        "value": "form.install_path",
        "className": "rounded-md border bg-muted/30 p-3 text-sm font-mono break-all",
        "meta": {
          "hiddenWhen": [
            {
              "path": "form.has_install_path",
              "operator": "equals",
              "value": false
            }
          ]
        }
      },
      {
        "type": "show-base",
        "value": "form.entry_file",
        "className": "rounded-md border bg-muted/30 p-3 text-sm font-mono break-all",
        "meta": {
          "hiddenWhen": [
            {
              "path": "form.has_entry_file",
              "operator": "equals",
              "value": false
            }
          ]
        }
      },
      {
        "type": "show-title",
        "value": "page.scanTitle",
        "meta": {
          "variant": "section",
          "hiddenWhen": [
            {
              "path": "form.has_skill_scan_files",
              "operator": "equals",
              "value": false
            }
          ]
        }
      },
      {
        "type": "show-base",
        "value": "form.skill_scan_summary",
        "className": "text-sm text-muted-foreground",
        "meta": {
          "hiddenWhen": [
            {
              "path": "form.has_skill_scan_files",
              "operator": "equals",
              "value": false
            }
          ]
        }
      },
      {
        "type": "show-title",
        "value": "page.sourceMetaTitle",
        "meta": {
          "variant": "section",
          "hiddenWhen": [
            {
              "path": "form.has_source_meta",
              "operator": "equals",
              "value": false
            }
          ]
        }
      },
      {
        "type": "show-base",
        "value": "form.source_meta_pretty",
        "className": "rounded-md border bg-muted/30 p-3 text-sm leading-6 whitespace-pre-wrap break-words",
        "meta": {
          "hiddenWhen": [
            {
              "path": "form.has_source_meta",
              "operator": "equals",
              "value": false
            }
          ]
        }
      },
      {
        "type": "show-table",
        "value": "form.skill_scan_files",
        "meta": {
          "hiddenWhen": [
            {
              "path": "form.has_skill_scan_files",
              "operator": "equals",
              "value": false
            }
          ],
          "rowKey": "path",
          "columns": [
            {
              "value": "path",
              "type": "show-base"
            },
            {
              "value": "kind",
              "type": "show-tag"
            },
            {
              "value": "size",
              "type": "show-base"
            }
          ]
        }
      },
      {
        "type": "show-title",
        "value": "page.configTitle",
        "meta": {
          "variant": "section",
          "hiddenWhen": [
            {
              "path": "form.has_config_rows",
              "operator": "equals",
              "value": false
            }
          ]
        }
      },
      {
        "type": "show-table",
        "value": "form.skill_config_rows",
        "meta": {
          "hiddenWhen": [
            {
              "path": "form.has_config_rows",
              "operator": "equals",
              "value": false
            }
          ],
          "rowKey": "id",
          "columns": [
            {
              "value": "name",
              "type": "show-base"
            },
            {
              "value": "key",
              "type": "show-base"
            },
            {
              "value": "type",
              "name": "变量类型",
              "type": "show-tag"
            },
            {
              "value": "value_hint",
              "name": "变量值",
              "type": "show-base",
              "className": "w-[360px] max-w-[360px] overflow-hidden text-ellipsis whitespace-nowrap [&>div]:block [&>div]:truncate [&_span]:truncate"
            },
            {
              "value": "status",
              "type": "show-tag"
            }
          ]
        }
      },
      {
        "type": "show-title",
        "value": "page.manifestTitle",
        "meta": {
          "variant": "section",
          "hiddenWhen": [
            {
              "path": "form.has_manifest",
              "operator": "equals",
              "value": false
            }
          ]
        }
      },
      {
        "type": "show-base",
        "value": "form.manifest_pretty",
        "className": "rounded-md border bg-muted/30 p-3 text-sm leading-6 whitespace-pre-wrap break-words",
        "meta": {
          "hiddenWhen": [
            {
              "path": "form.has_manifest",
              "operator": "equals",
              "value": false
            }
          ]
        }
      }
    ]
  },
  "data": {
    "page": {
      "installTitle": "安装信息",
      "scanTitle": "来源文件",
      "sourceMetaTitle": "_meta.json",
      "configTitle": "环境变量",
      "manifestTitle": "运行配置"
    },
    "form": {
      "service": "bot.agent.setting.AgentHook.LoadSkillDetail"
    }
  },
  "state": {},
  "action": {}
}
