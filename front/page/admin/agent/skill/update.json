{
  "page": {
    "name": "技能分类编辑",
    "parent": "bot/agent/skill_pack/list",
    "type": 2,
    "sort": 10,
    "auth": [
      {
        "key": "bot/agent/skill/update",
        "name": "技能分类编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-select",
        "value": "form.cate_id",
        "mode": "form",
        "option": {
          "model": "bot.agent.NewSkillCateModel",
          "filters": {
            "status": 1
          },
          "order": "sort asc,id asc"
        },
        "validate": [
          {
            "type": "required",
            "message": "技能分类不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[260px]",
          "assistant": false,
          "createOption": {
            "name": "新增分类",
            "pageRoute": "/bot/agent/skill_cate/update",
            "description": "新增后可直接作为当前技能的分类。",
            "size": "sm",
            "bodyClassName": "py-2",
            "selectCreated": true
          }
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": 0,
      "_partial": true,
      "cate_id": 1
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "bot.agent.setting.AgentHook.BeforeSaveSkillCate"
      }
    }
  }
}
