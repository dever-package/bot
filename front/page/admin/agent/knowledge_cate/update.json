{
  "page": {
    "name": "知识库分类",
    "parent": "bot/agent/knowledge_base/list",
    "type": 2,
    "sort": 2,
    "auth": [
      {
        "key": "bot/agent/knowledge_cate/create",
        "name": "知识库分类新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "bot/agent/knowledge_cate/update",
        "name": "知识库分类编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "分类名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": 0,
      "name": ""
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "bot.agent.knowledge.KnowledgeHook.BeforeSaveKnowledgeCate"
      }
    }
  }
}
