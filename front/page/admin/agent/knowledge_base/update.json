{
  "page": {
    "name": "知识库编辑",
    "parent": "bot/agent/knowledge_base/list",
    "type": 2,
    "sort": 10,
    "auth": [
      {
        "key": "bot/agent/knowledge_base/create",
        "name": "知识库新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "bot/agent/knowledge_base/update",
        "name": "知识库编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-select",
        "name": "知识库分类",
        "value": "form.cate_id",
        "mode": "form",
        "option": {
          "model": "bot.agent.NewKnowledgeCateModel",
          "filters": {
            "status": 1
          },
          "order": "sort asc,id asc"
        },
        "validate": [
          {
            "type": "required",
            "message": "知识库分类不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[260px]"
        }
      },
      {
        "type": "form-input",
        "name": "知识库名称",
        "placeholder": "例如：企业业务知识库",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "知识库名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-select",
        "name": "文档解析服务",
        "placeholder": "可选，选择 MinerU 服务",
        "value": "form.parser_service_id",
        "mode": "form",
        "option": {
          "service": "bot.agent.setting.OptionService.LoadKnowledgeParserServices"
        },
        "info": "可选。PDF、Office、图片等复杂文件需要解析正文时选择；Markdown、文本、代码等文件可以不选。",
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[360px]"
        }
      },
      {
        "type": "form-radio",
        "name": "检索模式",
        "value": "form.concept_graph_enabled",
        "mode": "form",
        "option": [
          {
            "id": 2,
            "value": "轻量模式"
          },
          {
            "id": 1,
            "value": "智能增强"
          }
        ],
        "info": "轻量模式使用本地全文检索，不调用索引模型、不生成向量；智能增强会启用 LLM 检索规划和概念图谱，可选向量检索。",
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[260px]"
        }
      },
      {
        "type": "form-select",
        "name": "索引模型",
        "placeholder": "选择 text 类型能力",
        "value": "form.index_power_id",
        "mode": "form",
        "option": {
          "service": "bot.agent.setting.OptionService.LoadTextPowers"
        },
        "validate": [
          {
            "type": "required",
            "message": "智能增强需要选择索引模型。",
            "when": [
              {
                "path": "form.concept_graph_enabled",
                "operator": "equals",
                "value": 1
              }
            ]
          }
        ],
        "info": "用于查询改写、检索规划、目录摘要和概念关系抽取。",
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[360px]",
          "showWhen": [
            {
              "path": "form.concept_graph_enabled",
              "operator": "equals",
              "value": 1
            }
          ]
        }
      },
      {
        "type": "form-select",
        "name": "向量能力",
        "placeholder": "可选，选择 embeddings 类型能力",
        "value": "form.embedding_power_id",
        "mode": "form",
        "option": {
          "service": "bot.agent.setting.OptionService.LoadEmbeddingPowers"
        },
        "info": "可选。选择后会额外生成语义向量，用于相似内容检索；不选择则只使用全文、规划和图谱检索。",
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[360px]",
          "showWhen": [
            {
              "path": "form.concept_graph_enabled",
              "operator": "equals",
              "value": 1
            }
          ]
        }
      },
      {
        "type": "form-number",
        "name": "检索数量",
        "value": "form.retrieve_limit",
        "mode": "form",
        "info": "智能体每次从该知识库最多取多少条候选知识，默认 5。",
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[160px]",
          "showWhen": [
            {
              "path": "form.concept_graph_enabled",
              "operator": "equals",
              "value": 1
            }
          ]
        }
      },
      {
        "type": "form-number",
        "name": "最大字数",
        "value": "form.max_context_chars",
        "mode": "form",
        "info": "最多注入到智能体上下文里的知识内容总字数，默认 6000。",
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[180px]",
          "showWhen": [
            {
              "path": "form.concept_graph_enabled",
              "operator": "equals",
              "value": 1
            }
          ]
        }
      },
      {
        "type": "form-number",
        "name": "扩展层数",
        "value": "form.graph_depth",
        "mode": "form",
        "info": "命中目录或知识点后继续向关联内容扩展的层数，默认 1。",
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[160px]",
          "showWhen": [
            {
              "path": "form.concept_graph_enabled",
              "operator": "equals",
              "value": 1
            }
          ]
        }
      },
      {
        "type": "form-number",
        "name": "匹配阈值",
        "value": "form.score_threshold",
        "mode": "form",
        "info": "向量检索的最低相似度，默认 0.35。",
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[160px]",
          "showWhen": [
            {
              "path": "form.concept_graph_enabled",
              "operator": "equals",
              "value": 1
            },
            {
              "path": "form.embedding_power_id",
              "operator": "notEquals",
              "value": 0
            },
            {
              "path": "form.embedding_power_id",
              "operator": "notEquals",
              "value": ""
            }
          ]
        }
      },
      {
        "type": "form-number",
        "name": "节点最大长度",
        "value": "form.node_max_length",
        "mode": "form",
        "info": "单个知识节点的大致最大字符数，默认 800。",
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[160px]",
          "showWhen": [
            {
              "path": "form.concept_graph_enabled",
              "operator": "equals",
              "value": 1
            }
          ]
        }
      },
      {
        "type": "form-number",
        "name": "长节点重叠",
        "value": "form.node_split_overlap",
        "mode": "form",
        "info": "长节点被保底拆分时，相邻节点重复保留的字符数，默认 120。",
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[160px]",
          "showWhen": [
            {
              "path": "form.concept_graph_enabled",
              "operator": "equals",
              "value": 1
            }
          ]
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": 0,
      "cate_id": 1,
      "name": "",
      "parser_service_id": "",
      "index_power_id": "",
      "embedding_power_id": "",
      "concept_graph_enabled": 2,
      "node_max_length": 800,
      "node_split_overlap": 120,
      "retrieve_limit": 5,
      "score_threshold": 0.35,
      "max_context_chars": 6000,
      "graph_depth": 1,
      "status": 1,
      "sort": 100
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "before": {
        "service": "bot.agent.knowledge.KnowledgeHook.BeforeSaveKnowledgeBase"
      },
      "after": {
        "service": "bot.agent.knowledge.KnowledgeHook.AfterSaveKnowledgeBase"
      },
      "model": "bot.agent.NewKnowledgeBaseModel"
    }
  }
}
