{
  "page": {
    "name": "自创技能",
    "icon": "sparkles",
    "parent": "bot/agent/skill_pack/list",
    "type": 2,
    "sort": 13
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "className": "gap-4",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5 sm:gap-6",
        "children": {
          "content-toolbar": {
            "type": "row",
            "className": "flex-wrap items-center gap-3"
          },
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          },
          "feedback-shell": {
            "type": "container"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page",
        "className": "min-w-0 flex-1"
      }
    ],
    "header-actions": [
      {
        "type": "show-button",
        "name": "返回技能方案",
        "className": "shrink-0",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "to": "/bot/agent/skill_pack/list"
        }
      },
      {
        "type": "show-button",
        "name": "创建新技能",
        "className": "shrink-0",
        "meta": {
          "variant": "default",
          "size": "sm",
          "icon": "sparkles"
        },
        "action": {
          "click": [
            {
              "type": "data",
              "key": "actionTarget.draftAgent",
              "value": {
                "id": 0,
                "pack_id": 1,
                "cate_id": 1,
                "source_skill_id": 0,
                "key": "",
                "name": "",
                "description": "",
                "skill_md": "",
                "files_json": "{}",
                "manifest": ""
              }
            },
            {
              "type": "data",
              "key": "actionTarget.draftAssistantMeta",
              "value": {
                "title": "创建新技能",
                "description": "通过 AI 对话生成技能；保存后回到列表继续测试或发布。"
              }
            },
            {
              "type": "modal",
              "key": "dialog.draftAssistant",
              "value": true
            }
          ]
        }
      }
    ],
    "content-toolbar": [
      {
        "type": "form-input",
        "placeholder": "搜索技能名称、标识或描述...",
        "value": "search.keyword",
        "mode": "search"
      },
      {
        "type": "form-select",
        "placeholder": "技能方案",
        "value": "search.pack_id",
        "mode": "search",
        "option": {
          "model": "bot.agent.NewSkillPackModel",
          "order": "sort asc,id asc"
        }
      },
      {
        "type": "form-select",
        "placeholder": "状态",
        "value": "search.status",
        "mode": "search"
      },
      {
        "type": "show-button",
        "name": "搜索",
        "meta": {
          "variant": "default",
          "size": "sm",
          "searchSubmit": true,
          "loadingText": "搜索中..."
        }
      },
      {
        "type": "show-button",
        "name": "重置",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "to": "/bot/agent/skill_draft/list"
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "savePath": "bot/agent/skill_draft/update",
          "rowKey": "id",
          "emptyText": "还没有自创技能草稿。点击右上角“创建新技能”，通过 AI 对话生成新技能。",
          "columns": [
            {
              "value": "name",
              "type": "show-base"
            },
            {
              "value": "key",
              "type": "show-base"
            },
            {
              "value": "pack.name",
              "name": "技能方案",
              "type": "show-base"
            },
            {
              "value": "cate.name",
              "name": "分类",
              "type": "show-base"
            },
            {
              "value": "status",
              "type": "show-tag"
            },
            {
              "value": "created_at",
              "type": "show-date"
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "sparkles",
                    "variant": "outline",
                    "size": "sm",
                    "description": "继续编辑",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.draftAgent",
                          "value": "$row"
                        },
                        {
                          "type": "data",
                          "key": "actionTarget.draftAssistantMeta",
                          "value": {
                            "title": "继续编辑",
                            "description": "通过 AI 对话继续修改技能；保存后回到列表继续测试或发布。"
                          }
                        },
                        {
                          "type": "modal",
                          "key": "dialog.draftAssistant",
                          "value": true
                        }
                      ]
                    }
                  },
                  {
                    "icon": "play",
                    "variant": "outline",
                    "size": "sm",
                    "description": "测试与发布",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.testDraft",
                          "value": "$row"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.test",
                          "value": true
                        }
                      ]
                    }
                  },
                  {
                    "icon": "trash-2",
                    "variant": "outline",
                    "size": "sm",
                    "description": "删除",
                    "className": "text-destructive hover:text-destructive",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.deleteDraft",
                          "value": "$row"
                        },
                        {
                          "type": "modal",
                          "key": "confirm.delete",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "draft-assistant-panel": [
      {
        "id": "skill-draft-agent",
        "type": "show-skill-creator",
        "meta": {
          "draftPath": "data.actionTarget.draftAgent",
          "agentPath": "data.actionTarget.skillCreatorAgent.key",
          "agentNamePath": "data.actionTarget.skillCreatorAgent.name",
          "openPath": "state.dialog.draftAssistant",
          "requestApi": "/bot/admin/agent/run",
          "streamApi": "/bot/admin/agent/stream",
          "stopApi": "/bot/admin/agent/stop",
          "paramApi": "/bot/admin/energon/power_params",
          "sessionEnabled": true,
          "sessionContext": {
            "prefix": "skill_draft",
            "idPath": "data.actionTarget.draftAgent.id",
            "fallback": "skill_draft:new"
          },
          "memoryEnabled": false,
          "historyEnabled": false,
          "newSessionEnabled": false,
          "skillDraftPatchApi": "/bot/admin/skill_draft/apply_patch",
          "skillDraftPatchAutoApply": false,
          "skillDraftPatchCloseOnSave": true,
          "skillDraftPatchContext": {
            "id": "data.actionTarget.draftAgent.id",
            "pack_id": "data.actionTarget.draftAgent.pack_id",
            "cate_id": "data.actionTarget.draftAgent.cate_id"
          },
          "reloadPageOnFinal": true,
          "reloadPageOnFinalKinds": ["skill_draft_patch"],
          "reloadPageOnFinalDelayMs": 500,
          "skillDraftPatchListPath": "/bot/agent/skill_draft/list",
          "blockMs": 1000,
          "placeholder": "描述要创建或修改的 skill。需要脚本、配置项、MCP、依赖或引用代码时直接说明。",
          "emptyText": "通过多轮对话生成技能内容。确认结果后点击“保存”，列表里会出现刚才创建的技能。",
          "inputContext": {
            "draft_id": "data.actionTarget.draftAgent.id",
            "pack_id": "data.actionTarget.draftAgent.pack_id",
            "cate_id": "data.actionTarget.draftAgent.cate_id",
            "draft": "data.actionTarget.draftAgent"
          }
        }
      }
    ],
    "draft-test-panel": [
      {
        "id": "skill-draft-test",
        "type": "show-skill-test",
        "meta": {
          "draftPath": "data.actionTarget.testDraft",
          "agentPath": "data.actionTarget.skillCreatorAgent.key",
          "agentNamePath": "data.actionTarget.skillCreatorAgent.name",
          "openPath": "state.dialog.test",
          "testApi": "/bot/admin/skill_draft/test",
          "publishApi": "/bot/admin/skill_draft/publish",
          "publishOptionsApi": "/bot/admin/skill_draft/publish_options",
          "skillDraftPatchApi": "/bot/admin/skill_draft/apply_patch",
          "sessionApi": "/bot/admin/assistant/session",
          "messageApi": "/bot/admin/assistant/message",
          "draftAssistantOpenPath": "state.dialog.draftAssistant",
          "draftAssistantDraftPath": "data.actionTarget.draftAgent",
          "draftAssistantMetaPath": "data.actionTarget.draftAssistantMeta",
          "reloadPageOnPublish": true,
          "reloadPageOnPublishDelayMs": 500,
          "requestApi": "/bot/admin/agent/run",
          "streamApi": "/bot/admin/agent/stream",
          "stopApi": "/bot/admin/agent/stop",
          "blockMs": 1000,
          "placeholder": "输入测试参数，每行一个；留空表示不带参数运行。",
          "emptyText": "输入一次测试参数开始测试。系统会先检查技能内容，再在沙箱中运行脚本。"
        }
      }
    ],
    "feedback-shell": [
      {
        "type": "feedback-modal",
        "name": "创建新技能",
        "meta": {
          "stateKey": "dialog.draftAssistant",
          "formSection": "draft-assistant-panel",
          "titlePath": "data.actionTarget.draftAssistantMeta.title",
          "descriptionPath": "data.actionTarget.draftAssistantMeta.description",
          "title": "创建新技能",
          "description": "通过 AI 对话生成技能；保存后回到列表继续测试或发布。",
          "size": "3xl",
          "bodyScroll": false,
          "footer": {
            "close": false,
            "confirm": false
          }
        }
      },
      {
        "type": "feedback-modal",
        "name": "测试技能",
        "meta": {
          "stateKey": "dialog.test",
          "formSection": "draft-test-panel",
          "title": "测试技能",
          "description": "先在沙箱中测试技能脚本；通过后可调整发布元信息并发布。",
          "size": "3xl",
          "bodyScroll": false,
          "footer": {
            "close": false,
            "confirm": false
          }
        }
      },
      {
        "type": "feedback-confirm",
        "name": "删除技能",
        "info": "确认删除当前创建中的技能吗？删除后不会影响已发布或已安装的技能。",
        "meta": {
          "stateKey": "confirm.delete"
        },
        "action": {
          "confirm": {
            "type": "delete",
            "model": "bot.agent.NewSkillDraftModel",
            "params": "actionTarget.deleteDraft"
          }
        }
      }
    ]
  },
  "data": {
    "page": {
      "title": "自创技能",
      "description": "展示通过 AI 创建或升级生成的自创技能草稿；保存后在这里继续测试和发布。"
    },
    "search": {
      "keyword": "",
      "pack_id": "",
      "status": ""
    },
    "table": {
      "searchFields": ["name", "key", "description"],
      "filterFields": ["pack_id", "status"],
      "model": "bot.agent.NewSkillDraftModel"
    },
    "actionTarget": {
      "draftAgent": {
        "id": 0,
        "pack_id": 1,
        "cate_id": 1,
        "key": "",
        "name": "",
        "description": "",
        "skill_md": "",
        "files_json": "{}",
        "manifest": ""
      },
      "draftAssistantMeta": {
        "title": "创建新技能",
        "description": "通过 AI 对话生成技能；保存后回到列表继续测试或发布。"
      },
      "testDraft": {},
      "deleteDraft": {},
      "skillCreatorAgent": {
        "key": "skill-creator",
        "name": "技能创建工程师"
      }
    }
  },
  "state": {
    "dialog": {
      "draftAssistant": false,
      "test": false
    },
    "confirm": {
      "delete": false
    }
  },
  "action": {}
}
